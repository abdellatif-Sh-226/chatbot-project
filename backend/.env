# Database configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=library_chatbot

# JWT configuration ou
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI API configuration (optional - chatbot works without it via fallback)
AI_API_KEY=key api 
AI_MODEL=gemini-2.5-flash
# App configuration
APP_NAME=Smart Library Management System
APP_VERSION=1.0.0
DEBUG=true
